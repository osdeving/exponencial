# VITE_BASE_PATH: caminho-base opcional quando o app é servido fora da raiz.
# Exemplo: "/exponencial/" para GitHub Pages em subdiretório.
VITE_BASE_PATH="/"

# VITE_UNLOCK_ALL_LESSONS: exceção de teste para ler todas as aulas sem concluir exercícios.
# Também dá para ativar no navegador com ?unlockLessons=1 ou localStorage.
VITE_UNLOCK_ALL_LESSONS="false"
